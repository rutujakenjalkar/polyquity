# Example .env file
# Copy this file to .env and fill in your actual values

# API Keys
GROQ_API_KEY=your_groq_api_key_here
OPENAI_API_KEY=your_openai_api_key_here
HF_TOKEN=your_huggingface_token_here

# Astra DB Configuration
ASTRA_DB_APPLICATION_TOKEN=your_astra_db_application_token_here
ASTRA_DB_API_ENDPOINT=your_astra_db_api_endpoint_here
ASTRA_COLLECTION=your_astra_collection_name_here

# PostgreSQL Database Configuration
POSTGRES_HOST=localhost
POSTGRES_DB=your_database_name_here
POSTGRES_USER=your_db_username_here
POSTGRES_PASSWORD=your_db_password_here
POSTGRES_PORT=5432

# Pinata Gateway (optional, defaults to gateway.pinata.cloud)
PINATA_GATEWAY=gateway.pinata.cloud

# Processing Parameters (optional, with defaults)
CHUNK_SIZE=100
CHUNK_OVERLAP=20
BATCH_SIZE=20